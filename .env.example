# ── Deployment ─────────────────────────────────────
DEPLOYMENT_MODE=local

# ── Claude API ─────────────────────────────────────
CLAUDE_API_KEY=your_anthropic_api_key_here

# ── Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# ── Features ───────────────────────────────────────
ENABLE_CAMERAS=false
ENABLE_SMART_HOME=false
ENABLE_WHATSAPP=false
ENABLE_VOICE=false
ENABLE_MONITORING=false

# ── Camera Recording Storage ───────────────────────
RECORDING_STORAGE=local
RECORDING_RETENTION_DAYS=7

# ── Govee (if ENABLE_SMART_HOME=true) ──────────────
GOVEE_API_KEY=your_govee_api_key_here

# ── Hybrid mode only ───────────────────────────────
LAPTOP_TAILSCALE_IP=100.65.12.119
LAPTOP_PORT=3001

# ── Security ───────────────────────────────────────
ENCRYPTION_KEY=generate_a_32_char_random_string

# ── Claude Models ───────────────────────────────────
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_SMART=claude-sonnet-4-6

# ── Govee ───────────────────────────────────────────────────
GOVEE_API_KEY=your_govee_api_key_here
